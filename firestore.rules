rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRestaurantId() {
      return userDoc().data.restaurantId;
    }

    function userPermissions() {
      return userDoc().data.permissions;
    }

    function hasPerm(perm) {
      return userDoc().exists() &&
        userPermissions() != null &&
        perm in userPermissions();
    }

    function restaurantScoped(resourceRestaurantId) {
      return request.auth != null && resourceRestaurantId == userRestaurantId();
    }

    function requestRestaurantScoped() {
      return request.auth != null && request.resource.data.restaurantId == userRestaurantId();
    }

    // -----------------------
    // Users (self only)
    // -----------------------
    match /users/{userId} {
      allow read: if request.auth != null && userId == request.auth.uid;
      allow update, create: if request.auth != null && userId == request.auth.uid;
    }

    // -----------------------
    // Restaurants + Roles (read-scoped)
    // -----------------------
    match /restaurants/{restaurantId} {
      allow read: if request.auth != null && restaurantId == userRestaurantId();
      allow update: if request.auth != null
        && restaurantId == userRestaurantId()
        && hasPerm("settings:edit")
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(["logoStoragePath", "logoUpdatedAt"]);
    }

    match /roles/{roleId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId();
      // MVP: restrict role write to users who can edit settings.
      allow write: if request.auth != null && hasPerm("settings:edit");
    }

    // -----------------------
    // POS <-> KDS core
    // -----------------------
    match /orders/{orderId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId();

      allow create: if request.auth != null
        && requestRestaurantScoped()
        && hasPerm("pos:use")
        && request.resource.data.status == "OPEN"
        && request.resource.data.kitchenStatus == "PENDING";

      allow update: if request.auth != null
        && resource.data.restaurantId == userRestaurantId()
        && hasPerm("kds:update")
        // MVP: KDS only updates kitchenStatus (keeps other fields stable).
        && request.resource.data.status == resource.data.status
        && request.resource.data.kitchenStatus != resource.data.kitchenStatus
        && request.resource.data.kitchenStatus in ["PENDING", "PREPARING", "READY", "SERVED"];
    }

    match /orderItems/{itemId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId();

      allow create: if request.auth != null
        && requestRestaurantScoped()
        && hasPerm("pos:use")
        && request.resource.data.kitchenStatus == "PENDING";

      allow update: if request.auth != null
        && resource.data.restaurantId == userRestaurantId()
        && hasPerm("kds:update")
        && request.resource.data.kitchenStatus in ["PREPARING", "READY", "SERVED"];
    }

    // -----------------------
    // Tables
    // -----------------------
    match /tables/{tableId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId();
      allow create: if request.auth != null && requestRestaurantScoped() && hasPerm("tables:manage");
      allow update: if request.auth != null
        && resource.data.restaurantId == userRestaurantId()
        && hasPerm("pos:use")
        && request.resource.data.restaurantId == userRestaurantId();
      allow delete: if false;
    }

    // -----------------------
    // Menu (categories + items)
    // -----------------------
    match /categories/{categoryId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId();
      allow create, update, delete: if request.auth != null
        && request.resource.data.restaurantId == userRestaurantId()
        && hasPerm("menu:edit");
    }

    match /menuItems/{menuItemId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId();
      allow create, update, delete: if request.auth != null
        && request.resource.data.restaurantId == userRestaurantId()
        && hasPerm("menu:edit");
    }

    // -----------------------
    // Staff management
    // -----------------------
    match /staff/{staffId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId()
        && hasPerm("staff:manage");

      allow create, update, delete: if request.auth != null
        && request.resource.data.restaurantId == userRestaurantId()
        && hasPerm("staff:manage");

      match /documents/{docId} {
        allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId()
          && hasPerm("staff:manage");
        allow create, update, delete: if request.auth != null
          && request.resource.data.restaurantId == userRestaurantId()
          && hasPerm("staff:manage");
      }
    }

    match /auditLogs/{logId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId()
        && (hasPerm("staff:manage") || hasPerm("settings:edit"));
      allow create: if request.auth != null && request.resource.data.restaurantId == userRestaurantId()
        && hasPerm("staff:manage");
      allow update, delete: if false;
    }

    // -----------------------
    // Inventory + recipes
    // -----------------------
    match /inventory/{inventoryId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId()
        && (hasPerm("kds:view") || hasPerm("inventory:view") || hasPerm("pos:use"));

      allow update: if request.auth != null
        && resource.data.restaurantId == userRestaurantId()
        && hasPerm("pos:use");

      allow create, delete: if false;
    }

    match /ingredients/{ingredientId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId();
      allow write: if false;
    }

    match /recipes/{recipeId} {
      allow read: if request.auth != null && resource.data.restaurantId == userRestaurantId()
        && (hasPerm("kds:view") || hasPerm("pos:use"));

      allow write: if false; // recipe edits reserved for later (inventory:edit / admin)
    }

    // -----------------------
    // Everything else (MVP: locked down)
    // -----------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
